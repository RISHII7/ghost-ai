# =========================================================================
# Ghost Arc Environment Variables Configuration
# Copy this file to .env.local and populate with your credentials.
# =========================================================================

# Clerk Authentication Config
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Liveblocks Collaboration Config
LIVEBLOCKS_SECRET_KEY=

# Trigger.dev Background Task Orchestration Config
TRIGGER_SECRET_KEY=
NEXT_PUBLIC_TRIGGER_PUBLIC_API_KEY=

# Database Connection (PostgreSQL with Prisma)
DATABASE_URL=

# Google Gemini AI Config
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: Override the default Gemini model (default: gemini-2.0-flash)
GEMINI_MODEL=
# Optional: Override the model used specifically for technical specification generation
GEMINI_SPEC_MODEL=

# Application URL
APP_URL=http://localhost:3000
